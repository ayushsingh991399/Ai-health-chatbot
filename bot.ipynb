    "from typing import TypedDict\n",
    "\n",
    "\n",
    "class HealthState(TypedDict):\n",
    "    topic: str\n",
    "    search_results: str\n",
    "    summary: str\n",
    "    quiz_question: str\n",
    "    answer: str\n",
    "    user_answer: str\n",
    "    feedback: str\n",
    "    continue_chat: str"
