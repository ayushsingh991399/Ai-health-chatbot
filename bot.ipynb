    "def grade_answer(state):\n",
    "\n",
    "    prompt = f\"\"\"\n",
    "        You are a medical instructor.\n",
    "\n",
    "        Summary:\n",
    "        {state[\"summary\"]}\n",
    "\n",
    "        Question:\n",
    "        {state[\"quiz_question\"]}\n",
    "\n",
    "        Patient's Answer:\n",
    "        {state[\"user_answer\"]}\n",
    "\n",
    "        Evaluate the patient's answer.\n",
    "\n",
    "        Return in this format:\n",
    "\n",
    "        Grade:\n"
    "\n",
    "        Explanation:\n",
    "        Explain why.\n",
    "\n",
    "        Citation:\n",
    "        Mention the relevant part of the summary.\n",
    "    \"\"\"\n",
    "\n",
    "    response = llm.invoke(prompt)\n",
    "\n",
    "    return {\n",
    "        \"feedback\": response.content\n",
    "    }"
   ]
