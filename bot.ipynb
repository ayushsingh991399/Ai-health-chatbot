    "def summarize(state):\n",
    "\n",
    "    prompt = f\"\"\"\n",
    "    You are a helpful medical assistant.\n",
    "\n",
    "    Summarize the following medical information in simple,\n",
    "    patient-friendly language.\n",
    "\n",
    "    Include:\n",
    "    - What it is\n",
    "    - Symptoms\n",
    "    - Causes\n",
    "    - Treatment\n",
    "    - Prevention\n",
    "\n",
    "    Search Results:\n",
    "    {state[\"search_results\"]}\n",
    "    \"\"\"\n",
    "\n",
    "    response = llm.invoke(prompt)\n",
    "\n",
    "    return {\n",
    "        \"summary\": response.content\n",
    "    }"
   ]
  },
